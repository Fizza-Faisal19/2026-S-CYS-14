import sysimport osfrom PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget, QLabel,                              QPushButton, QSlider, QFileDialog, QListWidget,                              QListWidgetItem, QFrame, QHBoxLayout, QVBoxLayout)from PyQt5.QtCore import Qt, QTimer, QUrlfrom PyQt5.QtGui import QFont, QColor, QPalettefrom PyQt5.QtMultimedia import QMediaPlayer, QMediaContentclass MusicPlayer(QMainWindow):    def __init__(self):        super().__init__()        # Window settings        self.setWindowTitle("Musify")        self.setFixedSize(1000, 600)        # Media player        self.player = QMediaPlayer()        self.player.positionChanged.connect(self.update_position)        self.player.durationChanged.connect(self.update_duration)        self.player.stateChanged.connect(self.update_play_button)        # Song list        self.songs = []        self.current_index = -1        # Timer for slider        self.timer = QTimer()        self.timer.setInterval(1000)        self.timer.timeout.connect(self.update_slider)        # Main widget        self.central = QWidget()        self.central.setStyleSheet("background-color: #121212;")        self.setCentralWidget(self.central)        # Build UI        self.build_sidebar()        self.build_main_area()        self.build_bottom_bar()    # ─────────────────────────────    # LEFT SIDEBAR    # ─────────────────────────────    def build_sidebar(self):        sidebar = QFrame(self.central)        sidebar.setGeometry(0, 0, 200, 530)        sidebar.setStyleSheet("background-color: #000000;")        # App name        app_name = QLabel("🎵 Musify", sidebar)        app_name.setGeometry(20, 20, 160, 40)        app_name.setFont(QFont("Arial", 16, QFont.Bold))        app_name.setStyleSheet("color: #1DB954;")        # Navigation labels        nav_items = ["🏠  Home", "🔍  Search", "📚  Your Library"]        y = 80        for item in nav_items:            lbl = QLabel(item, sidebar)            lbl.setGeometry(20, y, 160, 35)            lbl.setFont(QFont("Arial", 11))            lbl.setStyleSheet("color: #FFFFFF;")            y += 45        # Playlists label        playlist_lbl = QLabel("PLAYLISTS", sidebar)        playlist_lbl.setGeometry(20, 230, 160, 25)        playlist_lbl.setFont(QFont("Arial", 9, QFont.Bold))        playlist_lbl.setStyleSheet("color: #B3B3B3;")        # Playlist names        playlists = ["Chill Vibes", "Workout Mix", "Late Night", "Top Hits"]        y = 265        for p in playlists:            lbl = QLabel(p, sidebar)            lbl.setGeometry(20, y, 160, 30)            lbl.setFont(QFont("Arial", 10))            lbl.setStyleSheet("color: #B3B3B3;")            y += 35        # Add songs button        add_btn = QPushButton("+ Add Songs", sidebar)        add_btn.setGeometry(20, 470, 160, 40)        add_btn.setFont(QFont("Arial", 10))        add_btn.setStyleSheet("""            QPushButton {                background-color: #1DB954;                color: white;                border-radius: 20px;            }            QPushButton:hover {                background-color: #1ed760;            }        """)        add_btn.clicked.connect(self.add_songs)    # ─────────────────────────────    # MAIN CONTENT AREA    # ─────────────────────────────    def build_main_area(self):        main_frame = QFrame(self.central)        main_frame.setGeometry(200, 0, 800, 530)        main_frame.setStyleSheet("background-color: #121212;")        # Greeting        greeting = QLabel("Good Evening", main_frame)        greeting.setGeometry(30, 20, 400, 40)        greeting.setFont(QFont("Arial", 22, QFont.Bold))        greeting.setStyleSheet("color: #FFFFFF;")        subtitle = QLabel("Your daily mix", main_frame)        subtitle.setGeometry(30, 60, 300, 25)        subtitle.setFont(QFont("Arial", 11))        subtitle.setStyleSheet("color: #B3B3B3;")        # Song list header        headers = ["#", "TITLE", "ALBUM", "TIME"]        x_positions = [30, 70, 350, 680]        for i, h in enumerate(headers):            lbl = QLabel(h, main_frame)            lbl.setGeometry(x_positions[i], 100, 200, 25)            lbl.setFont(QFont("Arial", 9, QFont.Bold))            lbl.setStyleSheet("color: #B3B3B3;")        # Divider line        line = QFrame(main_frame)        line.setGeometry(30, 128, 740, 1)        line.setStyleSheet("background-color: #333333;")        # Song list widget        self.song_list = QListWidget(main_frame)        self.song_list.setGeometry(30, 135, 740, 370)        self.song_list.setStyleSheet("""            QListWidget {                background-color: #121212;                color: #FFFFFF;                border: none;                font-size: 13px;            }            QListWidget::item:selected {                background-color: #282828;                color: #1DB954;            }            QListWidget::item:hover {                background-color: #1a1a1a;            }        """)        self.song_list.itemDoubleClicked.connect(self.play_selected)    # ─────────────────────────────    # BOTTOM PLAYER BAR    # ─────────────────────────────    def build_bottom_bar(self):        bottom = QFrame(self.central)        bottom.setGeometry(0, 530, 1000, 70)        bottom.setStyleSheet("background-color: #181818; border-top: 1px solid #282828;")        # Album art placeholder        self.art_label = QLabel("🎵", bottom)        self.art_label.setGeometry(10, 10, 50, 50)        self.art_label.setAlignment(Qt.AlignCenter)        self.art_label.setStyleSheet("background-color: #282828; border-radius: 5px; font-size: 20px;")        # Song name        self.song_name_label = QLabel("No song playing", bottom)        self.song_name_label.setGeometry(70, 10, 180, 25)        self.song_name_label.setFont(QFont("Arial", 10, QFont.Bold))        self.song_name_label.setStyleSheet("color: #FFFFFF;")        # Artist name        self.artist_label = QLabel("", bottom)        self.artist_label.setGeometry(70, 35, 180, 20)        self.artist_label.setFont(QFont("Arial", 9))        self.artist_label.setStyleSheet("color: #B3B3B3;")        # Shuffle button        self.shuffle_btn = QPushButton("⇄", bottom)        self.shuffle_btn.setGeometry(280, 20, 35, 35)        self.shuffle_btn.setStyleSheet(self.control_btn_style())        # Previous button        self.prev_btn = QPushButton("⏮", bottom)        self.prev_btn.setGeometry(325, 20, 35, 35)        self.prev_btn.setStyleSheet(self.control_btn_style())        self.prev_btn.clicked.connect(self.play_prev)        # Play/Pause button        self.play_btn = QPushButton("▶", bottom)        self.play_btn.setGeometry(370, 15, 45, 45)        self.play_btn.setStyleSheet("""            QPushButton {                background-color: #FFFFFF;                color: #000000;                border-radius: 22px;                font-size: 16px;            }            QPushButton:hover {                background-color: #1DB954;                color: white;            }        """)        self.play_btn.clicked.connect(self.toggle_play)        # Next button        self.next_btn = QPushButton("⏭", bottom)        self.next_btn.setGeometry(425, 20, 35, 35)        self.next_btn.setStyleSheet(self.control_btn_style())        self.next_btn.clicked.connect(self.play_next)        # Repeat button        self.repeat_btn = QPushButton("↺", bottom)        self.repeat_btn.setGeometry(470, 20, 35, 35)        self.repeat_btn.setStyleSheet(self.control_btn_style())        # Progress slider        self.progress_slider = QSlider(Qt.Horizontal, bottom)        self.progress_slider.setGeometry(520, 10, 300, 20)        self.progress_slider.setStyleSheet("""            QSlider::groove:horizontal {                height: 4px;                background: #535353;                border-radius: 2px;            }            QSlider::sub-page:horizontal {                background: #1DB954;                border-radius: 2px;            }            QSlider::handle:horizontal {                background: #FFFFFF;                width: 12px;                height: 12px;                border-radius: 6px;                margin: -4px 0;            }        """)        self.progress_slider.sliderMoved.connect(self.seek)        # Time labels        self.current_time = QLabel("0:00", bottom)        self.current_time.setGeometry(520, 30, 40, 20)        self.current_time.setStyleSheet("color: #B3B3B3; font-size: 9px;")        self.total_time = QLabel("0:00", bottom)        self.total_time.setGeometry(790, 30, 40, 20)        self.total_time.setStyleSheet("color: #B3B3B3; font-size: 9px;")        # Volume slider        vol_icon = QLabel("🔊", bottom)        vol_icon.setGeometry(840, 25, 25, 20)        vol_icon.setStyleSheet("color: #FFFFFF; font-size: 12px;")        self.vol_slider = QSlider(Qt.Horizontal, bottom)        self.vol_slider.setGeometry(865, 28, 120, 15)        self.vol_slider.setRange(0, 100)        self.vol_slider.setValue(70)        self.vol_slider.setStyleSheet("""            QSlider::groove:horizontal {                height: 4px;                background: #535353;                border-radius: 2px;            }            QSlider::sub-page:horizontal {                background: #1DB954;                border-radius: 2px;            }            QSlider::handle:horizontal {                background: #FFFFFF;                width: 10px;                height: 10px;                border-radius: 5px;                margin: -3px 0;            }        """)        self.vol_slider.valueChanged.connect(self.change_volume)        self.player.setVolume(70)    # ─────────────────────────────    # HELPER STYLE    # ─────────────────────────────    def control_btn_style(self):        return """            QPushButton {                background-color: transparent;                color: #B3B3B3;                font-size: 16px;                border: none;            }            QPushButton:hover {                color: #FFFFFF;            }        """    # ─────────────────────────────    # FUNCTIONS    # ─────────────────────────────    def add_songs(self):        files, _ = QFileDialog.getOpenFileNames(            self, "Select Songs", "", "Audio Files (*.mp3 *.wav *.ogg)"        )        for f in files:            self.songs.append(f)            name = os.path.basename(f)            item = QListWidgetItem(f"  {len(self.songs)}     {name}          --          --")            self.song_list.addItem(item)    def play_selected(self, item):        self.current_index = self.song_list.row(item)        self.load_and_play(self.current_index)    def load_and_play(self, index):        if 0 <= index < len(self.songs):            path = self.songs[index]            self.player.setMedia(QMediaContent(QUrl.fromLocalFile(path)))            self.player.play()            name = os.path.basename(path)            self.song_name_label.setText(name[:25])            self.artist_label.setText("Unknown Artist")            self.timer.start()    def toggle_play(self):        if self.player.state() == QMediaPlayer.PlayingState:            self.player.pause()            self.timer.stop()        else:            self.player.play()            self.timer.start()    def play_next(self):        if self.songs:            self.current_index = (self.current_index + 1) % len(self.songs)            self.load_and_play(self.current_index)    def play_prev(self):        if self.songs:            self.current_index = (self.current_index - 1) % len(self.songs)            self.load_and_play(self.current_index)    def update_play_button(self, state):        if state == QMediaPlayer.PlayingState:            self.play_btn.setText("⏸")        else:            self.play_btn.setText("▶")    def update_position(self, position):        self.progress_slider.setValue(position)        seconds = position // 1000        self.current_time.setText(f"{seconds // 60}:{seconds % 60:02d}")    def update_duration(self, duration):        self.progress_slider.setRange(0, duration)        seconds = duration // 1000        self.total_time.setText(f"{seconds // 60}:{seconds % 60:02d}")    def update_slider(self):        self.progress_slider.setValue(self.player.position())    def seek(self, position):        self.player.setPosition(position)    def change_volume(self, value):        self.player.setVolume(value)# ─────────────────────────────# RUN APP# ─────────────────────────────if __name__ == "__main__":    app = QApplication(sys.argv)    window = MusicPlayer()    window.show()    sys.exit(app.exec_())